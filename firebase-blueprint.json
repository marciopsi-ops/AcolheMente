{
  "entities": {
    "Acolhimento": {
      "title": "Acolhimento",
      "description": "Formulário de triagem enviado pelos pacientes.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "viaAcesso": { "type": "string", "enum": ["Particular", "Corporativo"] },
        "empresa": { "type": "string" },
        "fonteRenda": { "type": "string" },
        "faixaSalarial": { "type": "string" },
        "dependentes": { "type": "string" },
        "planoSaude": { "type": "string" },
        "escolaridade": { "type": "string" },
        "moradia": { "type": "string" },
        "comodos": { "type": "string" },
        "internet": { "type": "string" },
        "dispositivo": { "type": "string" },
        "terapiaAnterior": { "type": "string" },
        "motivo": { "type": "string" },
        "status": { "type": "string", "enum": ["Aguardando Avaliação", "Triado"] },
        "valorRef": { "type": "number" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["nome", "email", "viaAcesso", "motivo", "createdAt", "status"]
    },
    "ServicoProfissional": {
      "title": "ServicoProfissional",
      "description": "Serviços específicos ofertados e cadastrados por profissionais.",
      "type": "object",
      "properties": {
        "profissionalId": { "type": "string" },
        "profissionalNome": { "type": "string" },
        "nome": { "type": "string" },
        "publicoAlvo": { "type": "string", "enum": ["Para pessoas", "Para Psicólogos", "Para Psicólogos e Terapeutas", "Para Empresas"] },
        "orcamentoAcessivel": { "type": "boolean" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["profissionalId", "profissionalNome", "nome", "publicoAlvo", "orcamentoAcessivel", "createdAt"]
    }
  },
  "firestore": {
    "acolhimentos": {
      "schema": { "$ref": "#/entities/Acolhimento" },
      "description": "Coleção de registros de acolhimento (público mas seguro para criação)."
    },
    "servicos_profissionais": {
      "schema": { "$ref": "#/entities/ServicoProfissional" },
      "description": "Serviços cadastrados por profissionais individuais."
    }
  }
}
